    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "4b3ea118cd8341b890927e6c76541267",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetDigitUV (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 1643.0,
            "y": 557.0,
            "width": 217.9998779296875,
            "height": 100.99993896484375
        }
    },
    "m_Slots": [
        {
            "m_Id": "14eb1ed1fdab4a73802de22afa55510f"
        },
        {
            "m_Id": "ea36333399e848a9bd8721a12d01383e"
        },
        {
            "m_Id": "725ba9510f06437186f1e4bce4899a59"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetDigitUV",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float col = fmod(CellIndex, 4.0);\r\nfloat row = floor(CellIndex / 4.0);\r\nfloat uMin = col * 0.25;\r\nfloat vMin = 1.0 - (row + 1.0) * 0.25;\r\nOutUV = float2(uMin + UV.x * 0.25, vMin + UV.y * 0.25);"
}

